%@exists

color(1).
color(2).
edge(1,3).
edge(1,10).
edge(2,3).
edge(3,4).
edge(3,6).
edge(4,5).
edge(5,10).
edge(6,7).
edge(7,10).
node(X):-edge(Y,X).
node(Y):-edge(Y,X).
edge(X,Y):-edge(Y,X).
asgn(X,C):-node(X),color(C),not nasgn(X,C).
nasgn(X,C):-node(X),color(C),not asgn(X,C).

:-asgn(X,C1),asgn(X,C2), C1!=C2.
colored(X):-asgn(X,C).
:-node(X),not colored(X).

%@forall
clique(X):-node(X), not outClique(X).
outClique(X):-node(X), not clique(X).

removed(X):-node(X),clique(Y),X!=Y,not edge(X,Y).

:-outClique(X),not removed(X).
:-clique(X),removed(X).
atLeast2:-clique(X),clique(Y),X<Y.
:-not atLeast2.
%@constraint
sat:-clique(X),clique(Y),asgn(X,C1),asgn(Y,C2),C1!=C2.
:-not sat.
